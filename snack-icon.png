// screens/home/HomeScreen.js

import React, {
  useMemo,
} from "react";

import {
  ScrollView,
  View,
} from "react-native";

import {
  useNavigation,
} from "@react-navigation/native";

import SectionHeader from "../../components/common/SectionHeader";
import EmptyState from "../../components/common/EmptyState";

import InfoCard from "../../components/cards/InfoCard";
import RevisionCard from "../../components/cards/RevisionCard";
import LectureCard from "../../components/cards/LectureCard";
import TestCard from "../../components/cards/TestCard";

import { useRevision } from "../../context/RevisionContext";
import { useLecture } from "../../context/LectureContext";
import { useTest } from "../../context/TestContext";
import { useMCQ } from "../../context/MCQContext";

import {
  GLOBAL_STYLES,
} from "../../styles/globalStyles";

export default function HomeScreen() {
  const navigation =
    useNavigation();

  const {
    topics,
  } = useRevision();

  const {
    lectures,
  } = useLecture();

  const {
    tests,
  } = useTest();

  const {
    streak,
  } = useMCQ();

  const todaysTopics =
    useMemo(
      () =>
        topics.filter(
          (topic) =>
            topic.isDueToday
        ),
      [topics]
    );

  const todaysLectures =
    useMemo(
      () =>
        lectures.filter(
          (lecture) =>
            !lecture.completed
        ),
      [lectures]
    );

  const todaysTests =
    useMemo(
      () =>
        tests.filter(
          (test) =>
            test.status ===
            "today"
        ),
      [tests]
    );

  return (
    <ScrollView
      style={
        GLOBAL_STYLES.screen
      }
    >
      <InfoCard
        title="MCQ Streak"
        value={`${streak || 0} Days`}
        onPress={() =>
          navigation.navigate(
            "MCQStreaks"
          )
        }
      />

      <SectionHeader
        title="Today's Revisions"
      />

      {todaysTopics.length >
      0 ? (
        todaysTopics.map(
          (topic) => (
            <RevisionCard
              key={topic.id}
              topicName={
                topic.name
              }
              revisionLabel="Due"
              onPress={() =>
                navigation.navigate(
                  "TopicDetails",
                  {
                    topicId:
                      topic.id,
                  }
                )
              }
            />
          )
        )
      ) : (
        <EmptyState
          title="No Revisions Due"
        />
      )}

      <SectionHeader
        title="Today's Lectures"
      />

      {todaysLectures.length >
      0 ? (
        todaysLectures
          .slice(0, 5)
          .map(
            (
              lecture
            ) => (
              <LectureCard
                key={
                  lecture.id
                }
                lectureName={
                  lecture.name
                }
                duration={
                  lecture.duration
                }
                tag={
                  lecture.tag
                }
                status="idle"
              />
            )
          )
      ) : (
        <EmptyState
          title="No Lectures"
        />
      )}

      <SectionHeader
        title="Today's Tests"
      />

      {todaysTests.length >
      0 ? (
        todaysTests.map(
          (test) => (
            <TestCard
              key={test.id}
              testType={
                test.type
              }
              testNumber={
                test.number
              }
              testDate={
                test.testDate
              }
              onPress={() =>
                navigation.navigate(
                  "TestDetails",
                  {
                    testId:
                      test.id,
                  }
                )
              }
            />
          )
        )
      ) : (
        <EmptyState
          title="No Tests Today"
        />
      )}

      <SectionHeader
        title="Quick Actions"
      />

      <InfoCard
        title="Revision Calendar"
        value="Open"
        onPress={() =>
          navigation.navigate(
            "RevisionCalendar"
          )
        }
      />

      <InfoCard
        title="MCQ Calendar"
        value="Open"
        onPress={() =>
          navigation.navigate(
            "MCQCalendar"
          )
        }
      />

      <InfoCard
        title="FST Readiness"
        value="Open"
        onPress={() =>
          navigation.navigate(
            "FSTPrep"
          )
        }
      />
    </ScrollView>
  );
}